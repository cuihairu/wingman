{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "wingman",
  "version": "0.1.0",
  "description": "Game Automation Programmable Control Engine",
  "dependencies": [
    {
      "name": "lua",
      "platform": "windows"
    },
    {
      "name": "sol2",
      "platform": "windows"
    },
    {
      "name": "opencv4",
      "platform": "windows",
      "default-features": false,
      "features": [
        "intrinsics",
        "jpeg",
        "png",
        "thread",
        "tiff",
        "webp"
      ]
    },
    {
      "name": "spdlog"
    },
    {
      "name": "nlohmann-json"
    },
    {
      "name": "asio"
    },
    {
      "name": "curl"
    },
    {
      "name": "sqlite3"
    },
    {
      "$comment": "Protobuf for Agent-Server communication",
      "name": "protobuf"
    },
    {
      "$comment": "OpenSSL for AES-256-GCM encryption",
      "name": "openssl"
    }
  ],
  "features": {
    "ocr": {
      "description": "Enable OCR support (Tesseract)",
      "dependencies": [
        {
          "name": "tesseract",
          "platform": "windows"
        }
      ]
    },
    "ml": {
      "description": "Enable ML/AI support (ONNX Runtime)",
      "dependencies": [
        {
          "name": "onnxruntime",
          "platform": "windows"
        }
      ]
    },
    "tests": {
      "description": "Build tests (requires GTest)",
      "dependencies": [
        {
          "name": "gtest"
        }
      ]
    },
    "python": {
      "description": "Enable Python scripting engine (embedded CPython + pybind11)",
      "dependencies": [
        {
          "name": "pybind11"
        }
      ]
    }
  },
  "builtin-baseline": "00d899c410b31467733472fc3a83a25729046b13"
}

{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "wingman",
  "version": "0.2.0",
  "description": "Game Automation Programmable Control Engine",
  "dependencies": [
    {
      "name": "lua",
      "platform": "windows"
    },
    {
      "name": "opencv4",
      "platform": "windows"
    },
    {
      "name": "spdlog",
      "platform": "windows"
    },
    {
      "name": "nlohmann-json",
      "platform": "windows"
    },
    {
      "name": "asio",
      "platform": "windows"
    },
    {
      "name": "curl",
      "platform": "windows"
    },
    {
      "name": "sqlite3",
      "platform": "windows"
    },
    {
      "$comment": "Protobuf for Agent-Server communication",
      "name": "protobuf",
      "platform": "windows",
      "features": ["icu"]
    },
    {
      "$comment": "ICU for protobuf support",
      "name": "icu",
      "platform": "windows"
    }
  ],
  "features": {
    "gui": {
      "description": "Build native GUI (ImGui)",
      "dependencies": [
        {
          "name": "imgui",
          "platform": "windows"
        },
        {
          "name": "directxtex",
          "platform": "windows"
        }
      ]
    },
    "ocr": {
      "description": "Enable OCR support (Tesseract)",
      "dependencies": [
        {
          "name": "tesseract",
          "platform": "windows"
        }
      ]
    },
    "ml": {
      "description": "Enable ML/AI support (ONNX Runtime)",
      "dependencies": [
        {
          "name": "onnxruntime",
          "platform": "windows"
        }
      ]
    },
    "tests": {
      "description": "Build tests (requires GTest)",
      "dependencies": [
        {
          "name": "gtest",
          "platform": "windows"
        }
      ]
    }
  },
  "builtin-baseline": "493710c788f428c30af8c853b812d94165d43df4"
}
